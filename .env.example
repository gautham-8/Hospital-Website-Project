# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# MongoDB connection string from Atlas (M0 free tier)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=

# Secret used to sign JWTs — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=

# Port the Express server listens on (Render sets this automatically)
PORT=4000
